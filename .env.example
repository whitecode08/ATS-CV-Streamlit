# =========================================================
# ATS AI Engine — Environment Variables Template
# Copy this file to `.env` and update values as needed.
# NEVER commit the `.env` file to version control.
# =========================================================

# Hybrid scoring weight: 0.0 = pure Dense, 1.0 = pure Sparse
ALPHA_WEIGHT=0.5

# SentenceTransformers model name (downloaded automatically on first run)
SENTENCE_MODEL=all-MiniLM-L6-v2

# spaCy model name (must be downloaded manually: python -m spacy download en_core_web_sm)
SPACY_MODEL=en_core_web_sm

# Optional: OpenAI API key (for future LLM integration in Phase 3+)
# OPENAI_API_KEY=sk-...
